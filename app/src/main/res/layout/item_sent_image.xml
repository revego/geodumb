<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@android:color/white"
    android:layout_marginBottom="8dp"
    android:elevation="2dp">

    <!-- Immagine principale -->
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:contentDescription="Immagine inviata"
        android:background="@color/pastel_gray_secondary" />

    <!-- Riga ID + Badge Tipo -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/textViewRecordId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ID: 0"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIPO"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginStart="8dp"

            app:chipBackgroundColor="@android:color/darker_gray"
            app:chipStrokeWidth="0dp"
            app:rippleColor="@android:color/transparent"
            app:ensureMinTouchTargetSize="false"/>

    </LinearLayout>

    <!-- Data -->
    <TextView
        android:id="@+id/textViewDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Data placeholder"
        android:layout_marginTop="6dp" />

    <!-- Indirizzo -->
    <TextView
        android:id="@+id/textViewAddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Indirizzo placeholder"
        android:layout_marginTop="4dp" />

    <!-- Informazioni utente -->
    <TextView
        android:id="@+id/textViewUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Utente: Non autenticato"
        android:textStyle="bold"
        android:layout_marginTop="6dp" />

    <!-- Bottoni azione -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/deleteButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delete"
            android:backgroundTint="@color/red"
            android:textColor="@color/white"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/mapButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Map"
            android:backgroundTint="@color/blue"
            android:textColor="@color/white"
            android:layout_marginStart="4dp" />
    </LinearLayout>

</LinearLayout>
