<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F4FAF6"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════════════
         APP BAR
    ══════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="#2D6A4F"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#2D6A4F"
            app:title="CityLog"
            app:titleTextColor="#FFFFFF"
            app:navigationIcon="@drawable/ic_menu_sort_by_size"
            app:navigationIconTint="#FFFFFF" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════
         CONTENUTO PRINCIPALE
    ══════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4FAF6"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- ══════════════════════════════════════
             BOTTOM NAVIGATION
             Preservate esatte le tre voci originali:
             navigation_home, navigation_dashboard, navigation_maps
        ══════════════════════════════════════ -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#2D6A4F"
            app:itemIconTint="@android:color/white"
            app:itemTextColor="@android:color/white"
            app:itemRippleColor="#4052B788"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu"
            app:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Scroll view principale -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:overScrollMode="never"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="18dp"
                android:paddingBottom="32dp">

                <!-- ══════════════════════════════════════
                     PROFILE CARD
                ══════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/profile_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#DEDEDE"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/img_account"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_profile"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/CircularShape"
                            app:strokeColor="#52B788"
                            app:strokeWidth="2dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:id="@+id/txt_username"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="User Name"
                                android:textColor="#1B2D27"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txt_token_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:textSize="11sp"
                                android:textColor="#52B788"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:visibility="gone" />

                        </LinearLayout>

                        <!-- Pallino status online -->
                        <View
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            android:background="@drawable/shape_dot_green" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ══════════════════════════════════════
                     MISSION BANNER
                ══════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/shape_mission_bg"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_info_outline"
                        app:tint="#52B788"
                        android:layout_marginEnd="9dp" />

                    <TextView
                        android:id="@+id/mission_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="La tua missione di oggi: segnala anomalie nel tuo quartiere!"
                        android:textColor="#2D6A4F"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <!-- ══════════════════════════════════════
                     PHOTO CARD
                     Gestione in MainActivity.kt:
                     - lastPhotoUri != null → mostra img_photo + stats_container, nascondi no_photo_content
                     - lastPhotoUri == null → nascondi img_photo, mostra no_photo_content
                ══════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_photo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FAFFFE">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- ── Stato A: ultima foto (visibile se lastPhotoUri != null) ── -->
                        <FrameLayout
                            android:id="@+id/photo_with_image_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone">

                            <ImageView
                                android:id="@+id/img_photo"
                                android:layout_width="match_parent"
                                android:layout_height="160dp"
                                android:scaleType="centerCrop"
                                android:adjustViewBounds="false"
                                android:contentDescription="Ultima foto scattata" />

                            <!-- Badge "Ultima foto" sovrapposto in alto a sinistra -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|start"
                                android:layout_margin="10dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/shape_badge_dark"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp">

                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/shape_dot_green"
                                    android:layout_marginEnd="5dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ultima foto"
                                    android:textColor="#FFFFFF"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Timestamp sovrapposto in alto a destra -->
                            <TextView
                                android:id="@+id/txt_photo_timestamp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:layout_margin="10dp"
                                android:background="@drawable/shape_badge_dark"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:text="oggi 14:32"
                                android:textColor="#D8F3DC"
                                android:textSize="10sp" />

                        </FrameLayout>

                        <!-- ── Stato B: nessuna foto (visibile se lastPhotoUri == null) ── -->
                        <LinearLayout
                            android:id="@+id/no_photo_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="22dp"
                            android:paddingBottom="4dp"
                            android:visibility="visible">

                            <ImageView
                                android:layout_width="54dp"
                                android:layout_height="54dp"
                                android:src="@drawable/ic_camera_placeholder"
                                app:tint="#C5E8D4"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nessuna foto scattata"
                                android:textColor="#9DC4B0"
                                android:textSize="14sp"
                                android:layout_marginBottom="16dp" />

                        </LinearLayout>

                        <!-- ── Statistiche (sempre visibili in entrambi gli stati) ── -->
                        <LinearLayout
                            android:id="@+id/stats_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="18dp">

                            <!-- Divisore visibile solo quando c'è la foto -->
                            <View
                                android:id="@+id/stats_divider"
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#EBF5EF"
                                android:layout_marginBottom="14dp"
                                android:visibility="gone" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LE TUE STATISTICHE"
                                android:textColor="#1B2D27"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.12"
                                android:layout_marginBottom="12dp" />

                            <!-- Stat: immagini inviate -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="11dp">

                                <View
                                    android:layout_width="7dp"
                                    android:layout_height="7dp"
                                    android:background="@drawable/shape_dot_green"
                                    android:layout_marginEnd="11dp" />

                                <TextView
                                    android:id="@+id/tvSentImagesCount"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Immagini inviate"
                                    android:textColor="#5A7569"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txt_images_sent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#2D6A4F"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- Stat: immagini pubblicate -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="11dp">

                                <View
                                    android:layout_width="7dp"
                                    android:layout_height="7dp"
                                    android:background="@drawable/shape_dot_blue"
                                    android:layout_marginEnd="11dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Immagini pubblicate"
                                    android:textColor="#5A7569"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txt_images_published"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#1A6B8A"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- Stat: nuove nel quartiere -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <View
                                    android:layout_width="7dp"
                                    android:layout_height="7dp"
                                    android:background="@drawable/shape_dot_amber"
                                    android:layout_marginEnd="11dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Nuove nel quartiere"
                                    android:textColor="#5A7569"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txt_new_in_neighborhood"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#9A6A00"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ══════════════════════════════════════
                     ACTION BUTTONS
                ══════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/buttons_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_take_photo"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Scatta Foto"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        app:icon="@drawable/ic_camera"
                        app:iconGravity="textStart"
                        app:iconTint="#FFFFFF"
                        app:iconPadding="8dp"
                        app:cornerRadius="14dp"
                        android:backgroundTint="#2D6A4F" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_send_email"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Invia Email"
                        android:textColor="#2D6A4F"
                        android:textSize="13sp"
                        app:icon="@drawable/ic_email"
                        app:iconGravity="textStart"
                        app:iconTint="#2D6A4F"
                        app:iconPadding="8dp"
                        app:cornerRadius="14dp"
                        app:strokeColor="#DEDEDE"
                        app:strokeWidth="1.5dp"
                        android:backgroundTint="#00000000" />

                </LinearLayout>

                <!-- ══════════════════════════════════════
                     HINT BAR + ISTRUZIONI ESPANDIBILI
                     Tap su "Dettagli" espande/collassa
                     il blocco instructions_detail sotto.
                ══════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/hint_bar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/shape_hint_bg"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_info_outline"
                        app:tint="#52B788"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/instructions_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Luce naturale, soggetto centrato, dispositivo fermo."
                        android:textColor="#4A6558"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.3" />

                    <TextView
                        android:id="@+id/btn_hint_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Dettagli ›"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/shape_btn_detail_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:onClick="toggleInstructions" />

                </LinearLayout>

                <!-- Istruzioni complete — espanse dal tap su "Dettagli" -->
                <LinearLayout
                    android:id="@+id/instructions_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/shape_mission_bg"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:visibility="gone">

                    <!-- Riga 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="14dp"
                            android:layout_height="wrap_content"
                            android:text="·"
                            android:textColor="#52B788"
                            android:textSize="20sp" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Assicurati che l'oggetto sia ben illuminato"
                            android:textColor="#4A6558"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>

                    <!-- Riga 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="14dp"
                            android:layout_height="wrap_content"
                            android:text="·"
                            android:textColor="#52B788"
                            android:textSize="20sp" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Inquadra il soggetto al centro dello schermo"
                            android:textColor="#4A6558"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>

                    <!-- Riga 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="14dp"
                            android:layout_height="wrap_content"
                            android:text="·"
                            android:textColor="#52B788"
                            android:textSize="20sp" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Mantieni il dispositivo fermo durante lo scatto"
                            android:textColor="#4A6558"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>

                    <!-- Riga 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="14dp"
                            android:layout_height="wrap_content"
                            android:text="·"
                            android:textColor="#52B788"
                            android:textSize="20sp" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Scatta quando l'immagine è a fuoco"
                            android:textColor="#4A6558"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>

                    <!-- Riga 5 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">
                        <TextView
                            android:layout_width="14dp"
                            android:layout_height="wrap_content"
                            android:text="·"
                            android:textColor="#52B788"
                            android:textSize="20sp" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Verifica che la foto sia nitida prima di inviare"
                            android:textColor="#4A6558"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>