<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4FAF6"
    android:fitsSystemWindows="true"
    tools:context=".PhotoDetailActivity">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2D6A4F"
        app:title="📸 Le tue segnalazioni"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="#FFFFFF"
        android:fitsSystemWindows="true"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Empty state (sovrapposto all'intera area sottostante la toolbar) -->
    <LinearLayout
        android:id="@+id/empty_state_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="32dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Icona placeholder -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_photo_placeholder"
            android:contentDescription="Nessuna segnalazione"
            android:layout_marginBottom="20dp" />

        <!-- Titolo vuoto -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱 Nessuna segnalazione"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2D6A4F"
            android:layout_marginBottom="8dp" />

        <!-- Descrizione -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Non hai ancora inviato immagini.\nScatta una foto e contribuisci a migliorare la città!"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="#5A7569"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="20dp" />

        <!-- Bottone per iniziare -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_take_photo_empty"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="📷 Scatta una foto"
            android:backgroundTint="#2D6A4F"
            app:cornerRadius="12dp"
            android:textColor="#FFFFFF"
            android:paddingStart="24dp"
            android:paddingEnd="24dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>