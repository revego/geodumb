    <style name="Theme.GeoDumb" parent="Theme.Material3.Light.NoActionBar">
        <!-- Color primary variations -->
        <item name="colorPrimary">@color/pastel_gray_primary</item>
        <item name="colorPrimaryContainer">@color/pastel_gray_primary_container</item>
        <item name="colorOnPrimary">@color/pastel_on_primary</item>
        <item name="colorOnPrimaryContainer">@color/pastel_on_primary_container</item>

        <!-- Color secondary variations -->
        <item name="colorSecondary">@color/pastel_gray_secondary</item>
        <item name="colorSecondaryContainer">@color/pastel_gray_secondary_container</item>
        <item name="colorOnSecondary">@color/pastel_on_secondary</item>
        <item name="colorOnSecondaryContainer">@color/pastel_on_secondary_container</item>

        <!-- Color tertiary variations -->
        <item name="colorTertiary">@color/pastel_gray_tertiary</item>
        <item name="colorTertiaryContainer">@color/pastel_gray_tertiary_container</item>
        <item name="colorOnTertiary">@color/pastel_on_tertiary</item>
        <item name="colorOnTertiaryContainer">@color/pastel_on_tertiary_container</item>

        <!-- Surface and background colors -->
        <item name="android:colorBackground">@color/pastel_background</item>
        <item name="colorSurface">@color/pastel_surface</item>
        <item name="colorSurfaceVariant">@color/pastel_surface_variant</item>

        <!--
            STATUS BAR — CityLog redesign
            Colore verde foresta coerente con la toolbar.
            windowLightStatusBar=false → icone di sistema bianche (leggibili su verde scuro).
        -->
        <item name="android:statusBarColor">@color/cl_green_deep</item>
        <item name="android:navigationBarColor">@color/cl_green_deep</item>
        <item name="android:windowLightStatusBar">false</item>

        <!--
            TOOLBAR — forza colori bianchi per titolo e icona navigazione.
            Necessario perché Material3 sovrascrive navigationIconTint
            con colorControlNormal del tema (grigio) ignorando l'XML del layout.
        -->
        <item name="toolbarStyle">@style/CityLogToolbarStyle</item>
    </style>

    <style name="CityLogToolbarStyle" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">#2D6A4F</item>
        <item name="titleTextColor">#FFFFFF</item>
        <item name="navigationIconTint">#FFFFFF</item>
        <item name="colorControlNormal">#FFFFFF</item>
        <item name="android:theme">@style/CityLogToolbarThemeOverlay</item>
    </style>

    <style name="CityLogToolbarThemeOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="colorControlNormal">#FFFFFF</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
    </style>

    <!-- Opzione 2: Tema Material Design 3 Dark -->
    <style name="Theme.GeoDumb.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/md_theme_dark_primary</item>
        <item name="colorPrimaryContainer">@color/md_theme_dark_primaryContainer</item>
        <item name="colorOnPrimary">@color/md_theme_dark_onPrimary</item>
        <item name="colorSecondary">@color/md_theme_dark_secondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_dark_secondaryContainer</item>
        <item name="colorOnSecondary">@color/md_theme_dark_onSecondary</item>
        <item name="colorTertiary">@color/md_theme_dark_tertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_dark_tertiaryContainer</item>
        <item name="colorOnTertiary">@color/md_theme_dark_onTertiary</item>
        <item name="android:statusBarColor">@color/md_theme_dark_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>